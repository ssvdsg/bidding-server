# 数据库配置
DB_HOST=your_db_host
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=bidding

# AI 配置
RELAY_AI_BASE_URL=https://your-ai-endpoint
RELAY_AI_MODEL=TEXT_DEEPSEEK_V4
RELAY_AI_API_KEY=your_api_key

# 服务器配置
PORT=3000

# CTYun 直连配置（如 AI_PROVIDER=ctyun）
CTYUN_USER=your_ctyun_user
CTYUN_PASSWORD=your_ctyun_password
CTYUN_MODEL=TEXT_DEEPSEEK_V4
AI_PROVIDER=ctyun
AI_PROMPT_FILE=ai_prompt.md

# 微信通知配置
WECHAT_HOOK_URL=your_wechat_hook_url
WECHAT_NOTICE_BASE_URL=https://your-domain
WECHAT_DEFAULT_ROOM=your_chatroom_id
